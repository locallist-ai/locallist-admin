{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npx expo export --platform web",
    "outputDirectory": "dist",
    "framework": null,
    "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
        }
    ]
}
